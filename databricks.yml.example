# Databricks Asset Bundle - Genie Room Tutorial (Agent Channel Analytics)
# Copy this file to databricks.yml and set your workspace host and CLI profile.
# Deploy with: databricks bundle deploy --target staging
# Do not run the job from CI; run it manually in the workspace after deploy.

bundle:
  name: agent-channel-genie-tutorial

workspace:
  host: https://YOUR_WORKSPACE.cloud.databricks.com
  profile: YOUR_CLI_PROFILE

variables:
  environment:
    description: "Environment (staging or dev)"
    default: staging

targets:
  staging:
    mode: development
    default: true
    variables:
      environment: staging
    workspace:
      host: https://YOUR_WORKSPACE.cloud.databricks.com
      profile: YOUR_CLI_PROFILE
      root_path: /Workspace/Users/${workspace.current_user.userName}/.bundle/${bundle.name}/staging

resources:
  jobs:
    genie_room_setup:
      name: genie_room_setup_${var.environment}
      description: "Genie Room Tutorial - one notebook setup (deploy only; run manually)"
      tasks:
        - task_key: run_genie_setup
          notebook_task:
            notebook_path: ./One_Notebook_Genie_Room_Setup.py
          timeout_seconds: 900
